########################################
# Secrets push helper
########################################
cat > scripts/push_secrets.sh <<'SH'
#!/usr/bin/env bash
set -euo pipefail

if [[ ! -f .env ]]; then
  echo "Create .env from .env.sample first" >&2
  exit 1
fi

# shellcheck disable=SC2046
export $(grep -v '^#' .env | xargs)

# Required
gh secret set GCP_PROJECT_ID --body "$GCP_PROJECT_ID"
gh secret set TF_STATE_BUCKET --body "$TF_STATE_BUCKET"
gh secret set GCS_KNOWLEDGE_BUCKET --body "$GCS_KNOWLEDGE_BUCKET"

echo "$GCP_SA_KEY_B64" | gh secret set GCP_SA_KEY_B64 --body -

gh secret set FIREBASE_TOKEN --body "$FIREBASE_TOKEN"
gh secret set VERCEL_TOKEN --body "$VERCEL_TOKEN"

# Optional integrations
[[ -n "${PINATA_JWT:-}" ]] && gh secret set PINATA_JWT --body "$PINATA_JWT"
[[ -n "${WEB3STORAGE_TOKEN:-}" ]] && gh secret set WEB3STORAGE_TOKEN --body "$WEB3STORAGE_TOKEN"
[[ -n "${PLAY_JSON_KEY_B64:-}" ]] && gh secret set PLAY_JSON_KEY_B64 --body "$PLAY_JSON_KEY_B64"

echo "✅ GitHub secrets pushed."
SH
chmod +x scripts/push_secrets.sh

