cat > .github/workflows/aikya-final-merge.yml <<'YML'
name: Aikya Final Merge — Charevati ♾️

on:
  push:
    branches: [ "main" ]
  workflow_dispatch: {}

jobs:
  deploy:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      id-token: write
    env:
      GCP_PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}
      GCP_SA_KEY_B64: ${{ secrets.GCP_SA_KEY_B64 }}
      FIREBASE_TOKEN: ${{ secrets.FIREBASE_TOKEN }}
      VERCEL_TOKEN: ${{ secrets.VERCEL_TOKEN }}
      TF_STATE_BUCKET: ${{ secrets.TF_STATE_BUCKET }}
      GCS_KNOWLEDGE_BUCKET: ${{ secrets.GCS_KNOWLEDGE_BUCKET }}
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install CLIs
        run: |
          curl -sL https://firebase.tools | bash
          npm i -g vercel @google-cloud/storage
          sudo apt-get update && sudo apt-get install -y jq

      - name: Decode SA key
        run: |
          echo "$GCP_SA_KEY_B64" | base64 -d > ${HOME}/gcp-key.json
          echo "GOOGLE_APPLICATION_CREDENTIALS=${HOME}/gcp-key.json" >> $GITHUB_ENV

      - name: Auth gcloud
        uses: google-github-actions/auth@v2
        with:
          credentials_json: ${{ steps.decode_key.outputs.json || '' }}
        continue-on-error: true

      - name: Terraform Init/Apply (bucket iam, UBA)
        if: env.TF_STATE_BUCKET != ''
        run: |
          sudo apt-get install -y unzip >/dev/null
          curl -fsSL https://releases.hashicorp.com/terraform/1.7.5/terraform_1.7.5_linux_amd64.zip -o tf.zip
          unzip -o tf.zip -d /usr/local/bin
          cd infra
          terraform init -backend-config="bucket=$TF_STATE_BUCKET" -backend-config="prefix=terraform/state"
          terraform apply -auto-approve

      - name: Vercel Deploy (prod)
        run: |
          vercel pull --yes --environment=production
          vercel build
          vercel deploy --prebuilt --prod --token "$VERCEL_TOKEN"

      - name: Firebase Deploy
        run: |
          firebase deploy --token "$FIREBASE_TOKEN"

      - name: Caption/Autonorm Hooks (placeholders)
        run: |
          echo "Triggering caption + autonorm webhooks..."
          # curl -X POST ${{ secrets.CAPTION_SYNC_URL }} -H "Authorization: Bearer ${{ secrets.CAPTION_TOKEN }}" || true

      - name: IPFS Sync (placeholder)
        run: |
          node scripts/ipfs_sync_placeholder.js || true

YML

