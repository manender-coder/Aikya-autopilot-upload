SHELL:=/bin/bash
-include .env

help:
	@echo "Targets: tf-init | tf-apply | deploy-web | deploy-firebase | upload-play | ipfs-sync | broadcast"

tf-init:
	cd infra && terraform init -backend-config="bucket=$(TF_STATE_BUCKET)" -backend-config="prefix=terraform/state"

tf-apply:
	cd infra && terraform apply -auto-approve

deploy-web:
	vercel --token $$VERCEL_TOKEN --prod

deploy-firebase:
	firebase deploy --token $$FIREBASE_TOKEN

upload-play:
	cd android && bundle exec fastlane android deploy

ipfs-sync:
	node scripts/ipfs_sync_placeholder.js

broadcast:
	node scripts/broadcast_placeholder.js
MK

