// Node: Sign a V4 URL for a GCS object
const { Storage } = require('@google-cloud/storage');
const path = require('path');

(async () => {
  const [,, bucket, object, expires='15m'] = process.argv;
  if(!bucket || !object) {
    console.error('Usage: node sign_url_node.js <bucket> <object> [expires]');
    process.exit(1);
  }
  const storage = new Storage();
  const options = { version: 'v4', action: 'read', expires: Date.now() + parseInt(expires)*60*1000 };
  const [url] = await storage.bucket(bucket).file(object).getSignedUrl(options);
  console.log(url);
})();
JS

